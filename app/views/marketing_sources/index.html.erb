<section class="section">
<div class="row">
  <div class="col-md-6">
    <h1>Marketing Sources</h1>
  </div>
</div>

<%= form_tag(marketing_sources_path, remote: false, method: :get) do %>
  <div class="row">
    <div class="col-xs-6 col-md-3">
        <div class="form__group">
          <%= select_tag :property_id, marketing_source_properties(@property_id), class: 'form__control' %>
        </div>
    </div>
    <div class="col-xs-2 col-md-2">
      <%= submit_tag 'Select Property', class: "btn btn--small btn--primary" %>
    </div>
    <div class="col-md-6">
      <%= link_to('Marketing Sources CSV Export', report_marketing_sources_path(marketing_sources_report: {property_ids: [@property_id], report_type: 'source_export'}, format: :csv), class: "btn btn--xs btn--info") %>
      <%= link_to('Marketing Expenses CSV Export', report_marketing_sources_path(marketing_sources_report: {property_ids: [@property_id], report_type: 'expense_export'}, format: :csv), class: "btn btn--xs btn--info") %>
      <%= link_to('Phone Numbers CSV Export', report_marketing_sources_path(marketing_sources_report: {report_type: 'phone_export'}, format: :csv), class: "btn btn--xs btn--info") %>
      <%= link_to('Ad Spend Report', report_marketing_sources_path(marketing_sources_report: {property_ids: [@property_id], report_type: 'adspend'}, format: :csv), class: "btn btn--xs btn--info") %>
      <%= link_to('Ad Redirects', stats_referral_bounces_path, class: "btn btn--xs btn--info") %>
    </div>
  </div>
<% end if policy(MarketingSource).select_property?%>


<% if @marketing_sources.empty? %>
  <div class="row">
    <div class="col-md-12">
      <% if policy(MarketingSource).new? %>
        <%= link_to 'Add a Marketing Source', new_marketing_source_path, class: "btn btn--small btn--primary"  %>
      <% end %>
    </div>
  </div>
<% end %>

<% @marketing_sources.group_by{|s| s.property }.each do |property, marketing_sources| %>
  <%
    prop_total_spend = MarketingSource.total_spend(property)
    prop_total_spend_ytd = MarketingSource.total_spend_ytd(property)
    prop_total_leads = MarketingSource.total_leads(property)
    prop_total_leads_ytd = MarketingSource.total_leads_ytd(property)
    prop_total_conversions = MarketingSource.total_conversions(property)
    prop_total_conversions_ytd = MarketingSource.total_conversions_ytd(property)
    prop_spend_per_lead = prop_total_spend / [prop_total_leads, 1].max.to_d
    prop_spend_per_conversion = prop_total_spend / [prop_total_conversions, 1].max.to_d
  %>
  <div class="row">
    <div class="col-xs-12 col-md-3">
      <h2><%= property.name %></h2>
      <% if policy(MarketingSource).new? %>
        <%= link_to 'Add a Marketing Source', new_marketing_source_path(property_id: marketing_sources.first&.property_id), class: "btn btn--small btn--primary"  %>
      <% end %>
      <br/><br/>
      <div class="row card card--well card card--well card--small">
        <div class="col-md-12 col-xs-6">
          <table class="marketing_source--stats--table">
            <tbody>
              <tr>
                <td>Total Spend:</td>
                <td> <%= number_to_currency(prop_total_spend) %></td>
              </tr>
              <tr>
                <td>Spend YTD:</td>
               <td><%= number_to_currency(prop_total_spend_ytd) %></td>
              </tr>
              <tr>
                <td>Per Lead:</td>
                <td><%= number_to_currency(prop_spend_per_lead) %></td>
              </tr>
              <tr>
                <td>Per Conversion:</td>
               <td><%= number_to_currency(prop_spend_per_conversion) %></td>
              </tr>
              <tr>
                <td>Total Leads:</td>
                <td><%= prop_total_leads %></td>
              </tr>
              <tr>
                <td>Leads YTD:</td>
               <td><%= prop_total_leads_ytd %></td>
              </tr>
              <tr>
                <td>Conversions:</td>
                <td><%= prop_total_conversions %></td>
              </tr>
              <tr>
                <td>Conversions YTD:</td>
                <td><%= prop_total_conversions_ytd %></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="col-xs-12 col-md-9">
      <%= render partial: 'marketing_source', collection: marketing_sources %>
    </div>
  </div>
<% end %>
</section>